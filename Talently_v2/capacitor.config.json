{
  "appId": "com.talently.app",
  "appName": "Talently",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "android": {
    "allowMixedContent": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1500,
      "backgroundColor": "#1392EC",
      "showSpinner": false,
      "androidScaleType": "CENTER_CROP"
    },
    "Keyboard": {
      "resize": "body"
    }
  }
}
